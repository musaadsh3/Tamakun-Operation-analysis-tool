# ═══════════════════════════════════════════════════════
# TAMAKUN SaaS - Environment Variables
# ═══════════════════════════════════════════════════════

# App secret key (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-change-me

# Database URL
# SQLite (local):
DATABASE_URL=sqlite:///./tamakun.db
# PostgreSQL (cPanel production):
# DATABASE_URL=postgresql://operationtamakun_operation_user:YOUR_PASSWORD_HERE@localhost/operationtamakun_operation

# External Postgres (Salla ingest) — get the real values from your DBA / ops, do NOT commit them.
EXTERNAL_DB_HOST=127.0.0.1
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_USERNAME=changeme
EXTERNAL_DB_PASSWORD=changeme
EXTERNAL_DB_NAME=changeme
EXTERNAL_DB_TYPE=postgres
EXTERNAL_USE_SSL=false
